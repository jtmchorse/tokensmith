{
  "$description": "Meridian — an invented demo design system for tokensmith. Clean-room: not derived from any employer's tokens. Alias chains run base -> brand -> semantic (up to 3 deep) on purpose, so resolution demos show something real.",
  "color": {
    "$type": "color",
    "base": {
      "gray-0": { "$value": "#ffffff" },
      "gray-50": { "$value": "#f7f8fa" },
      "gray-100": { "$value": "#eceef1" },
      "gray-300": { "$value": "#c6ccd4" },
      "gray-600": { "$value": "#5b6472" },
      "gray-800": { "$value": "#2a303a" },
      "gray-900": { "$value": "#161a21" },
      "blue-500": { "$value": "#3573e8" },
      "blue-600": { "$value": "#2557c7" },
      "blue-700": { "$value": "#1a419c" },
      "red-600": { "$value": "#c92c3d" },
      "green-600": { "$value": "#1e8a4c" },
      "amber-500": { "$value": "#e8a221" }
    },
    "brand": {
      "primary": { "$value": "{color.base.blue-600}", "$description": "Meridian brand blue." },
      "primary-strong": { "$value": "{color.base.blue-700}" },
      "accent": { "$value": "{color.base.amber-500}" }
    },
    "action": {
      "primary": { "$value": "{color.brand.primary}", "$description": "Default action color. 3-deep chain: action.primary -> brand.primary -> base.blue-600." },
      "primary-hover": { "$value": "{color.brand.primary-strong}" },
      "destructive": { "$value": "{color.base.red-600}" }
    },
    "surface": {
      "default": { "$value": "{color.base.gray-0}" },
      "raised": { "$value": "{color.base.gray-50}", "$description": "Cards, popovers — one step off the page." },
      "sunken": { "$value": "{color.base.gray-100}" },
      "inverse": { "$value": "{color.base.gray-900}" }
    },
    "text": {
      "default": { "$value": "{color.base.gray-900}" },
      "muted": { "$value": "{color.base.gray-600}" },
      "on-action": { "$value": "{color.base.gray-0}" },
      "positive": { "$value": "{color.base.green-600}" },
      "danger": { "$value": "{color.action.destructive}", "$description": "3-deep chain via action.destructive." }
    },
    "border": {
      "default": { "$value": "{color.base.gray-300}" },
      "focus": { "$value": "{color.brand.primary}" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "12": { "$value": "48px" },
    "inset": {
      "control": { "$value": "{space.2}", "$description": "Padding inside buttons, inputs." },
      "card": { "$value": "{space.4}" },
      "section": { "$value": "{space.8}" }
    }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "16px" },
    "pill": { "$value": "9999px" },
    "interactive": { "$value": "{radius.md}", "$description": "Buttons, inputs, chips share this." }
  },
  "type": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": ["Inter", "system-ui", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "12px" },
      "sm": { "$value": "14px" },
      "md": { "$value": "16px" },
      "lg": { "$value": "20px" },
      "xl": { "$value": "24px" },
      "2xl": { "$value": "32px" }
    }
  },
  "shadow": {
    "raised": {
      "$type": "shadow",
      "$value": {
        "color": "#161a2126",
        "offsetX": "0px",
        "offsetY": "2px",
        "blur": "8px",
        "spread": "0px"
      },
      "$description": "Pairs with color.surface.raised."
    },
    "overlay": {
      "$type": "shadow",
      "$value": {
        "color": "#161a2140",
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "-4px"
      }
    }
  },
  "duration": {
    "$type": "duration",
    "fast": { "$value": "120ms" },
    "medium": { "$value": "200ms" },
    "slow": { "$value": "320ms" }
  }
}
